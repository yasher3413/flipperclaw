#pragma once
// fc_secrets.h.example — Copy to fc_secrets.h and fill in your credentials.
// fc_secrets.h is gitignored and must NEVER be committed.
//
// These values are compile-time defaults. They can be overridden at runtime
// via the serial CLI (fc> wifi_set, fc> set_api_key, etc.) and stored in NVS.

#define FC_SECRET_WIFI_SSID        "YourWiFiName"
#define FC_SECRET_WIFI_PASS        "YourWiFiPassword"

// Anthropic API key (starts with sk-ant-api03-)
// Get one at: https://console.anthropic.com/
#define FC_SECRET_API_KEY          "sk-ant-api03-xxxxx"

// "anthropic" or "openai"
#define FC_SECRET_MODEL_PROVIDER   "anthropic"

// Optional: Tavily API key for web search tool
// Get one at: https://tavily.com/
#define FC_SECRET_TAVILY_KEY       ""

// Optional: Brave Search API key (fallback if Tavily not set)
// Get one at: https://brave.com/search/api/
#define FC_SECRET_BRAVE_KEY        ""
